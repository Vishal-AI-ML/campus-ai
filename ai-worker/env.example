# Campus AI - AI Worker environment
# Copy this file to `.env` and fill in at least the provider you use.
# Location: E:\campus-ai\ai-worker\.env

# Which LLM backend to use: "groq" or "gemini"
LLM_PROVIDER=groq

# --- Groq (fast, free tier) -> https://console.groq.com/keys ---
GROQ_API_KEY=your-groq-key-here
GROQ_MODEL=llama-3.3-70b-versatile

# --- Google Gemini -> https://aistudio.google.com/app/apikey ---
GOOGLE_API_KEY=your-gemini-key-here
GEMINI_MODEL=gemini-2.5-flash

# Optional: scoring consistency (0.0 - 1.0)
LLM_TEMPERATURE=0.2
