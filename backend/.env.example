# Campus AI backend - environment template.
# Copy to `.env` and fill real values locally. NEVER commit the real `.env`.
# In production these are set on the host (Render), not in a file.

# --- App ---------------------------------------------------------------
PROJECT_NAME="Campus AI API"
# development | production  (production refuses to boot with weak secrets)
ENVIRONMENT=development

# --- Database ----------------------------------------------------------
# Runtime connection string. In prod MUST be a NOBYPASSRLS role (e.g. app_user)
# so Row-Level Security actually filters rows.
DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:5432/postgres

# Owner-role URL used ONLY by Alembic migrations (DDL + FORCE RLS).
# Needs the table owner (e.g. Supabase `postgres`). Falls back to DATABASE_URL.
MIGRATION_DATABASE_URL=postgresql+psycopg://OWNER:PASSWORD@HOST:5432/postgres

# --- Auth / JWT --------------------------------------------------------
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-use-a-strong-random-value
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- AI worker ---------------------------------------------------------
AI_WORKER_URL=http://127.0.0.1:8100
# Shared secret (X-Worker-Token). MUST match the worker. Empty = open worker (unsafe).
AI_WORKER_TOKEN=

# --- CORS --------------------------------------------------------------
# Comma-separated allowed frontend origins in prod, e.g. https://campus-ai.vercel.app
CORS_ORIGINS=

# --- Observability -----------------------------------------------------
# Sentry DSN. Empty = disabled.
SENTRY_DSN=

# --- File storage (Supabase Storage, signed URLs) ----------------------
# Leave all three EMPTY to keep file uploads OFF (the /files routes 503).
# Turn on by creating a PRIVATE bucket and pasting your project URL + the
# service_role key (Dashboard > Project Settings > API). service_role is a
# powerful server-only secret - never put it in the frontend.
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_STORAGE_BUCKET=campus-uploads
