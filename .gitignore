cd E:\campus-ai
$gi = @'
# Python
__pycache__/
*.py[cod]
.venv/
*.sqlite

# Env / secrets
.env
.env.*

# Node / Next
node_modules/
.next/
next-env.d.ts

# Logs
*.log

# Vector store
qdrant_storage/

# QA / local artifacts — never commit real faces or screenshots
test/
ui_shots/
ui_smoke.py
'@ -replace "`r`n","`n"
[System.IO.File]::WriteAllText("E:\campus-ai\.gitignore", $gi)